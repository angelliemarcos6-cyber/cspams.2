# API base URL used by frontend requests.
# Local direct backend example: http://127.0.0.1:8000
# Cloudflare quick preview (single tunnel via Vite proxy): /
VITE_API_BASE_URL=http://127.0.0.1:8000

# Dev proxy target used by Vite for /api, /sanctum, and /broadcasting.
VITE_DEV_BACKEND_URL=http://127.0.0.1:8000
VITE_REVERB_APP_KEY=cspams-reverb-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
