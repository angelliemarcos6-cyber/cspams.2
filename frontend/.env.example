# API base URL used by frontend requests.
# Vercel production with rewrites to Render: /
# Local/frontend proxy setups (Vite dev proxy or Cloudflare quick preview): /
VITE_API_BASE_URL=/

# Render backend target used by the Vite dev proxy for /api, /sanctum, and /broadcasting.
# Vercel production uses frontend/vercel.json rewrites instead.
VITE_DEV_BACKEND_URL=https://cspams-2.onrender.com
VITE_REVERB_APP_KEY=cspams-reverb-key
# Leave blank for local fallback behavior (current browser host + ws://:8080).
# Vercel/Render production should point directly at the Render backend hostname.
# Example:
# VITE_REVERB_HOST=your-backend.onrender.com
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https
VITE_REVERB_HOST=
VITE_REVERB_PORT=
VITE_REVERB_SCHEME=
# VITE_REVERB_TLS=true
